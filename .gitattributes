# Force consistent line endings regardless of OS checkout settings.
# Shell scripts MUST have LF — CRLF shebangs break Linux execution.
*.sh     text eol=lf
*.py     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.hcl    text eol=lf
*.json   text eol=lf
*.j2     text eol=lf
*.conf   text eol=lf
*.cfg    text eol=lf
# Windows scripts should keep CRLF
*.ps1    text eol=crlf
*.psm1   text eol=crlf
*.bat    text eol=crlf
*.cmd    text eol=crlf
