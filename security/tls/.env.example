# =============================================================================
# TLS / Certificate Management — Configuration
# =============================================================================
# Copy to .env and fill in your values before running any TLS scripts.
# Source with:  source .env
# =============================================================================

# ── Let's Encrypt ─────────────────────────────────────────────────────────────
# Your domain name (must have public DNS pointing to this server)
DOMAIN="yourdomain.com"

# Email for Let's Encrypt expiry notifications
LE_EMAIL="admin@yourdomain.com"

# Web server type: nginx or apache
WEB_SERVER="nginx"

# ── AWS ACM (Certificate Manager) ─────────────────────────────────────────────
# AWS CLI must be configured first: run 'aws configure'
# Or set these environment variables:
# export AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
# export AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG..."
# export AWS_DEFAULT_REGION="eu-west-2"

# ── Azure Key Vault ────────────────────────────────────────────────────────────
# Azure CLI must be logged in first: run 'az login'
# AZURE_KEYVAULT_NAME="my-keyvault"
# AZURE_RESOURCE_GROUP="my-resource-group"

# ── GCP Certificate Manager ───────────────────────────────────────────────────
# GCP CLI must be logged in first: run 'gcloud auth login'
# GCP_PROJECT_ID="my-project-id"
