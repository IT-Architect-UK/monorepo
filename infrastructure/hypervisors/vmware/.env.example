# =============================================================================
# VMware vCenter / ESXi — Default Configuration
# =============================================================================
#
# SETUP INSTRUCTIONS
# ──────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in YOUR values below
# 3. In PowerShell, load it before running scripts:
#      Get-Content .env | Where-Object { $_ -notmatch '^#' -and $_ -ne '' } |
#        ForEach-Object { $name,$val = $_.split('=',2); Set-Item "env:$name" $val }
#    OR set variables directly in your PowerShell session (see CONFIGURATION.md)
#
# SECURITY
# ─────────
# .env is listed in .gitignore — it will NEVER be committed to GitHub.
# For production: use a secrets manager (HashiCorp Vault, CyberArk) instead.
#
# WHERE TO FIND THESE VALUES
# ──────────────────────────
# vCenter UI → Home → Hosts and Clusters — shows your datacenter/cluster names
# vCenter UI → Home → Storage — shows your datastore names
# vCenter UI → Home → Networking — shows your port group names
# =============================================================================

# ── vCenter Connection ────────────────────────────────────────────────────────

# vCenter Server hostname or IP address
# Example: vcenter.homelab.local  |  192.168.1.20
VCENTER_HOST="vcenter.homelab.local"

# vCenter username (include domain for AD accounts)
# Example: administrator@vsphere.local  |  admin@homelab.local
VCENTER_USERNAME="administrator@vsphere.local"

# vCenter password
# Leave blank to be prompted at runtime (more secure)
VCENTER_PASSWORD=""

# ── Infrastructure ────────────────────────────────────────────────────────────

# Datacenter name
# vCenter UI → Home → Hosts and Clusters → top-level datacenter object
VCENTER_DATACENTER="Datacenter"

# Cluster name (or leave blank to use a specific host instead)
VCENTER_CLUSTER="Cluster01"

# ESXi host (only needed if NOT using a cluster)
# VCENTER_HOST_DIRECT="esxi01.homelab.local"

# Datastore for VM disks
# vCenter UI → Home → Storage → select a datastore → note its name
VCENTER_DATASTORE="datastore1"

# VM Network port group name
# vCenter UI → Home → Networking → your network name
VCENTER_NETWORK="VM Network"

# Folder in vCenter to store VMs (use "/" for root)
VCENTER_FOLDER="/Datacenter/vm"

# ── VM Defaults ───────────────────────────────────────────────────────────────
DEFAULT_MEMORY_GB="4"
DEFAULT_CPU_COUNT="2"

# ── SSH Key (for Linux template preparation) ──────────────────────────────────
DEFAULT_SSH_PUBLIC_KEY="${HOME}/.ssh/id_ed25519.pub"
DEFAULT_SSH_PRIVATE_KEY="${HOME}/.ssh/id_ed25519"
