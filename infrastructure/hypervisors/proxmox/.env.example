# =============================================================================
# Proxmox VE — Default Configuration
# =============================================================================
#
# SETUP INSTRUCTIONS
# ──────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in YOUR values below
# 3. Source it before running scripts:  source .env
#    OR add to your shell profile:      echo "source ~/proxmox/.env" >> ~/.bashrc
#
# SECURITY
# ─────────
# .env is listed in .gitignore — it will NEVER be committed to GitHub.
# Never share this file. Treat it like a password file.
#
# WHERE TO FIND THESE VALUES
# ──────────────────────────
# Proxmox Web UI → Datacenter (left panel) → your node name appears there
# Proxmox Web UI → Datacenter → Storage — lists all storage pools
# Proxmox Web UI → your node → Network — lists all bridges
#
# These scripts run DIRECTLY ON THE PROXMOX HOST (SSH in or use the
# Proxmox shell in the web UI). They do not connect remotely.
# =============================================================================

# ── Node & Storage ────────────────────────────────────────────────────────────

# The name of your Proxmox node (shown in the left panel of the web UI)
# Example: pve  |  proxmox01  |  homelab-pve
PROXMOX_NODE="pve"

# Storage pool for VM disks
# Find at: Proxmox UI → Datacenter → Storage
# Common values: local-lvm  |  local-zfs  |  ceph-pool  |  ssd-pool
PROXMOX_STORAGE="local-lvm"

# Storage pool where ISO images and cloud images are stored
# Usually the same as above or just "local"
PROXMOX_ISO_STORAGE="local"

# Network bridge VMs connect to
# Find at: Proxmox UI → your node → Network
# Default is vmbr0 for the first bridge
PROXMOX_BRIDGE="vmbr0"

# ── VM Defaults ───────────────────────────────────────────────────────────────
# These are used as defaults when not specified via command-line flags.
# All can be overridden per-script with --memory, --cores etc.

DEFAULT_MEMORY_MB="2048"    # RAM in MB   (2048 = 2 GB)
DEFAULT_CORES="2"           # vCPU cores
DEFAULT_DISK_GB="20"        # Disk size in GB

# ── SSH Key ───────────────────────────────────────────────────────────────────
# Public key injected into new VMs via cloud-init (for passwordless SSH login)
# Generate one with: ssh-keygen -t ed25519 -C "homelab"
# Then copy the public key path here:
DEFAULT_SSH_PUBLIC_KEY="${HOME}/.ssh/id_ed25519.pub"

# Private key used to SSH into VMs after deployment (for template maintenance)
DEFAULT_SSH_PRIVATE_KEY="${HOME}/.ssh/id_ed25519"

# ── Default VM User ───────────────────────────────────────────────────────────
# Username created inside new VMs by cloud-init
DEFAULT_CI_USER="sysadmin"
