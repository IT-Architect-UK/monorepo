# =============================================================================
# /etc/ssh/sshd_config — managed by Ansible (roles/common)
# Generated from: roles/common/templates/sshd_config.j2
# Do not edit this file manually — changes will be overwritten on next run.
# =============================================================================

# ── Network ───────────────────────────────────────────────────────────────────
Port {{ ssh_port | default(22) }}
AddressFamily inet
ListenAddress 0.0.0.0

# ── Authentication ────────────────────────────────────────────────────────────
PermitRootLogin no
PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys
PasswordAuthentication no
PermitEmptyPasswords no
ChallengeResponseAuthentication no

# ── Security limits ───────────────────────────────────────────────────────────
MaxAuthTries 3
MaxSessions 5
LoginGraceTime 30

# ── Session ───────────────────────────────────────────────────────────────────
# Disconnect idle sessions after 10 minutes (5 min × 2 checks)
ClientAliveInterval 300
ClientAliveCountMax 2

# ── Forwarding (disabled — enable per server if needed) ──────────────────────
AllowAgentForwarding no
AllowTcpForwarding no
X11Forwarding no
PermitTunnel no

# ── Banner and MOTD ───────────────────────────────────────────────────────────
Banner /etc/issue.net
PrintMotd no
PrintLastLog yes

# ── Logging ───────────────────────────────────────────────────────────────────
SyslogFacility AUTH
LogLevel INFO

# ── Subsystems ───────────────────────────────────────────────────────────────
Subsystem sftp /usr/lib/openssh/sftp-server
{% if ssh_password_auth_users | default([]) | length > 0 %}

# ── Per-user overrides ────────────────────────────────────────────────────────
# Accounts allowed password authentication (var: ssh_password_auth_users).
# Everything else stays key-only per PasswordAuthentication above.
# Match blocks must remain at the end of this file.
{% for user in ssh_password_auth_users %}
Match User {{ user }}
    PasswordAuthentication yes
{% endfor %}
{% endif %}
