<?xml version="1.0" encoding="utf-8"?>
<!--
  autounattend.xml — Windows Server 2025 unattended install (Proxmox)
  =====================================================================
  This answer file drives the Windows installer automatically:
    • Selects Windows Server 2025 Standard Evaluation (Desktop Experience)
    • Partitions the disk (EFI + MSR + Windows)
    • Creates the 'packer' local admin account
    • Enables WinRM on port 5985 so Packer can run provisioners
    • Disables the firewall during the build (cleanup-windows.ps1 re-enables it)

  Proxmox-specific notes:
    • VM disk type: SATA — Windows can see SATA without extra drivers
    • VM NIC type : e1000 — Windows has this driver in-box
    • virtio-win ISO is still mounted so provision-windows.ps1 can install
      the QEMU Guest Agent (required for Proxmox 'qm agent' commands)

  IMPORTANT — password:
    The packer account password is hardcoded here as a placeholder.
    Change "PackerBuild2025!" to a strong password and set the SAME value
    in PKR_VAR_winrm_password before running the build:

      export PKR_VAR_winrm_password="PackerBuild2025!"

  Edition names (use with packer validate to confirm yours):
    Windows Server 2025 Standard Evaluation
    Windows Server 2025 Standard Evaluation (Desktop Experience)
    Windows Server 2025 Datacenter Evaluation
    Windows Server 2025 Datacenter Evaluation (Desktop Experience)
-->
<unattend xmlns="urn:schemas-microsoft-com:unattend">

  <!-- ═══════════════════════════════════════════════════════════════════════
       Pass 1: windowsPE
       Runs inside Windows PE before setup touches the disk.
       ═══════════════════════════════════════════════════════════════════════ -->
  <settings pass="windowsPE">

    <component name="Microsoft-Windows-International-Core-WinPE"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <InputLocale>en-GB</InputLocale>
      <UILanguage>en-US</UILanguage>
      <UILanguageFallback>en-US</UILanguageFallback>
      <UserLocale>en-GB</UserLocale>
      <SystemLocale>en-US</SystemLocale>
    </component>

    <component name="Microsoft-Windows-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

      <!-- Disk layout: EFI (100 MB) + MSR (16 MB) + Windows (remainder) -->
      <DiskConfiguration>
        <WillShowUI>OnError</WillShowUI>
        <Disk wcm:action="add">
          <DiskID>0</DiskID>
          <WillWipeDisk>true</WillWipeDisk>
          <CreatePartitions>
            <CreatePartition wcm:action="add">
              <Order>1</Order>
              <Type>EFI</Type>
              <Size>100</Size>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>2</Order>
              <Type>MSR</Type>
              <Size>16</Size>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>3</Order>
              <Type>Primary</Type>
              <Extend>true</Extend>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order>
              <PartitionID>1</PartitionID>
              <Label>EFI</Label>
              <Format>FAT32</Format>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order>
              <PartitionID>2</PartitionID>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>3</Order>
              <PartitionID>3</PartitionID>
              <Label>Windows</Label>
              <Letter>C</Letter>
              <Format>NTFS</Format>
            </ModifyPartition>
          </ModifyPartitions>
        </Disk>
      </DiskConfiguration>

      <!-- VirtIO drivers for WinPE: without these, Setup can't see the
           VirtIO SCSI disk or use the VirtIO NIC. The virtio-win ISO's drive
           letter in WinPE isn't predictable, so every likely letter is
           listed; Setup ignores paths that don't exist. "2k25" = Server 2025. -->
      <DriverPaths>
        <PathAndCredentials wcm:action="add" wcm:keyValue="1">
          <Path>D:\vioscsi\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="2">
          <Path>E:\vioscsi\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="3">
          <Path>F:\vioscsi\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="4">
          <Path>G:\vioscsi\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="5">
          <Path>D:\NetKVM\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="6">
          <Path>E:\NetKVM\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="7">
          <Path>F:\NetKVM\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="8">
          <Path>G:\NetKVM\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="9">
          <Path>D:\viostor\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="10">
          <Path>E:\viostor\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="11">
          <Path>F:\viostor\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="12">
          <Path>G:\viostor\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="13">
          <Path>D:\Balloon\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="14">
          <Path>E:\Balloon\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="15">
          <Path>F:\Balloon\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="16">
          <Path>G:\Balloon\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="17">
          <Path>D:\vioserial\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="18">
          <Path>E:\vioserial\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="19">
          <Path>F:\vioserial\2k25\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="20">
          <Path>G:\vioserial\2k25\amd64</Path>
        </PathAndCredentials>
      </DriverPaths>

      <ImageInstall>
        <OSImage>
          <InstallFrom>
            <MetaData wcm:action="add">
              <Key>/IMAGE/INDEX</Key>
              <Value>WINDOWS_IMAGE_INDEX</Value>
            </MetaData>
          </InstallFrom>
          <InstallTo>
            <DiskID>0</DiskID>
            <PartitionID>3</PartitionID>
          </InstallTo>
          <WillShowUI>OnError</WillShowUI>
        </OSImage>
      </ImageInstall>

      <UserData>
        <AcceptEula>true</AcceptEula>
        <FullName>Packer</FullName>
        <Organization>IT-Architect-UK</Organization>
        <!-- No ProductKey = 180-day evaluation. Add your KMS/MAK key here if licensed. -->
      </UserData>

    </component>
  </settings>

  <!-- ═══════════════════════════════════════════════════════════════════════
       Pass 4: specialize
       Runs on first real boot after files are copied. Sets hostname and RDP.
       ═══════════════════════════════════════════════════════════════════════ -->
  <settings pass="specialize">

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <ComputerName>WIN-PACKER</ComputerName>
      <TimeZone>UTC</TimeZone>
    </component>

    <component name="Microsoft-Windows-TerminalServices-LocalSessionManager"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <fDenyTSConnections>false</fDenyTSConnections>
    </component>

    <component name="Microsoft-Windows-International-Core"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <InputLocale>en-GB</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-GB</UserLocale>
    </component>

  </settings>

  <!-- ═══════════════════════════════════════════════════════════════════════
       Pass 7: oobeSystem
       Runs just before the Windows Welcome screen. Creates the packer user,
       sets passwords, and enables WinRM so Packer can connect.
       ═══════════════════════════════════════════════════════════════════════ -->
  <settings pass="oobeSystem">

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

      <!-- Auto-login as packer so FirstLogonCommands run without prompting -->
      <AutoLogon>
        <Password>
          <Value>PackerBuild2025!</Value>
          <PlainText>true</PlainText>
        </Password>
        <Enabled>true</Enabled>
        <Username>packer</Username>
        <LogonCount>5</LogonCount>
      </AutoLogon>

      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <NetworkLocation>Work</NetworkLocation>
        <ProtectYourPC>1</ProtectYourPC>
        <SkipMachineOOBE>true</SkipMachineOOBE>
        <SkipUserOOBE>true</SkipUserOOBE>
      </OOBE>

      <UserAccounts>
        <!-- Built-in Administrator password (disabled after packer user created) -->
        <AdministratorPassword>
          <Value>PackerBuild2025!</Value>
          <PlainText>true</PlainText>
        </AdministratorPassword>

        <!-- packer — local admin account Packer uses via WinRM -->
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Password>
              <Value>PackerBuild2025!</Value>
              <PlainText>true</PlainText>
            </Password>
            <Group>Administrators</Group>
            <DisplayName>Packer Build Account</DisplayName>
            <Name>packer</Name>
            <Description>Temporary build account — removed by cleanup-windows.ps1</Description>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <!--
        FirstLogonCommands run synchronously in order after first logon.
        These commands bootstrap WinRM so Packer can take over.
      -->
      <FirstLogonCommands>

        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Description>Enable WinRM service</Description>
          <CommandLine>cmd.exe /c winrm quickconfig -q</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Description>Allow WinRM unencrypted transport (HTTP/5985 for Packer)</Description>
          <CommandLine>cmd.exe /c winrm set winrm/config/service @{AllowUnencrypted="true"}</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>3</Order>
          <Description>Enable Basic authentication</Description>
          <CommandLine>cmd.exe /c winrm set winrm/config/service/auth @{Basic="true"}</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>4</Order>
          <Description>Raise WinRM memory limit</Description>
          <CommandLine>cmd.exe /c winrm set winrm/config/winrs @{MaxMemoryPerShellMB="512"}</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>5</Order>
          <Description>Open Windows Firewall for WinRM HTTP</Description>
          <CommandLine>cmd.exe /c netsh advfirewall firewall add rule name="WinRM-HTTP" dir=in localport=5985 protocol=TCP action=allow</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>6</Order>
          <Description>Open Windows Firewall for RDP</Description>
          <CommandLine>cmd.exe /c netsh advfirewall firewall add rule name="RDP-TCP" dir=in localport=3389 protocol=TCP action=allow</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>7</Order>
          <Description>Disable firewall for the build (re-enabled by cleanup-windows.ps1)</Description>
          <CommandLine>cmd.exe /c netsh advfirewall set allprofiles state off</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>8</Order>
          <Description>Set WinRM service to auto-start</Description>
          <CommandLine>cmd.exe /c sc config WinRM start= auto</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>

      </FirstLogonCommands>

    </component>
  </settings>

</unattend>
