# =============================================================================
# Packer — Credentials & Sensitive Variables
# =============================================================================
#
# SETUP INSTRUCTIONS
# ──────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in YOUR values below
# 3. Before running packer build, load the variables:
#      source .env
#    Packer automatically picks up any environment variable prefixed PKR_VAR_
#    matching a declared variable name.
#
# SECURITY
# ─────────
# .env is in .gitignore — it will NEVER be committed to GitHub.
# The sensitive variables in variables.pkr.hcl are marked sensitive=true,
# which prevents them appearing in Packer logs even if accidentally set.
#
# HOW THIS WORKS WITH PACKER
# ──────────────────────────
# Packer reads PKR_VAR_<name> environment variables automatically.
# So  PKR_VAR_proxmox_password="secret"  sets the 'proxmox_password' variable
# without it ever appearing in a var file or command line.
#
# You still pass non-sensitive config via the var files:
#   packer build -var-file="environments/homelab.pkrvars.hcl" <template>.pkr.hcl
# =============================================================================

# ── Proxmox ───────────────────────────────────────────────────────────────────
# Proxmox Web UI URL (always ends in /api2/json)
# Where to find: the URL in your browser when logged into Proxmox, e.g.:
#   https://192.168.1.10:8006  →  add /api2/json
export PKR_VAR_proxmox_url="https://192.168.1.10:8006/api2/json"

# Proxmox login (root@pam for local root, or user@pve for Proxmox realm)
export PKR_VAR_proxmox_username="root@pam"

# Proxmox password or API token secret
# Tip: create a dedicated API token instead of using root password:
#   Proxmox UI → Datacenter → Permissions → API Tokens → Add
#   Then use format: user@pam!tokenid  and set the token secret below
export PKR_VAR_proxmox_password="YOUR_PROXMOX_PASSWORD_HERE"

# ── VMware vCenter ────────────────────────────────────────────────────────────
# vCenter hostname (not the ESXi host — the vCenter appliance)
export PKR_VAR_vsphere_server="vcenter.homelab.local"
export PKR_VAR_vsphere_username="administrator@vsphere.local"
export PKR_VAR_vsphere_password="YOUR_VCENTER_PASSWORD_HERE"

# ── AWS ───────────────────────────────────────────────────────────────────────
# Packer uses the AWS CLI credential chain — you don't need to set these
# if you've already run 'aws configure' or use IAM roles/instance profiles.
# Only set these if you want to override the default AWS CLI credentials:
# export AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
# export AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
# export AWS_DEFAULT_REGION="eu-west-2"

# ── Azure ─────────────────────────────────────────────────────────────────────
# Packer uses the Azure CLI credential chain — run 'az login' first.
# Only set these if you want to override:
# export PKR_VAR_azure_subscription_id="00000000-0000-0000-0000-000000000000"

# ── GCP ───────────────────────────────────────────────────────────────────────
# Packer uses Application Default Credentials — run 'gcloud auth login' first.
# Only set these if you want to override:
# export GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"

# ── Packer SSH (build VM temp user) ──────────────────────────────────────────
# These are the credentials Packer uses to SSH into the VM DURING the build.
# They are only used temporarily — cleanup.sh removes them from the final image.
export PKR_VAR_ssh_username="packer"
export PKR_VAR_ssh_password="Packer-Temp-P@ss1"
